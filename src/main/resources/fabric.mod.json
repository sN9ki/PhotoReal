{
  "schemaVersion": 1,
  "id": "photoreal_terrain",
  "version": "${version}",
  "name": "Photoreal Terrain",
  "description": "Replaces vanilla blocky terrain with smooth mathematical density functions for cinematic world generation.",
  "authors": ["PhotorealDev"],
  "contact": {},
  "license": "MIT",
  "icon": "assets/photoreal_terrain/icon.png",

  "environment": "*",

  "entrypoints": {
    "main": [
      "com.photoreal.terrain.PhotorealTerrainMod"
    ],
    "client": [
      "com.photoreal.terrain.PhotorealTerrainClient"
    ]
  },

  "mixins": [
    "photoreal_terrain.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.14.22",
    "fabric-api": "*",
    "minecraft": "~1.20.1",
    "sodium": ">=0.5.3"
  },

  "suggests": {
    "indium": "*"
  },

  "breaks": {
    "optifabric": "*"
  }
}
